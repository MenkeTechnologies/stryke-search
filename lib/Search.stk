fn Search::exists ($field) {
    val $r = { field => $field }
    Search::_decode("exists", search__exists_query(to_json($r)))->{value}
}

## Match by document ids. $values: arrayref.
fn Search::ids ($values) {
    val $list = ref($values) eq "ARRAY" ? $values : [$values]
    val $r = { values => $list }
    Search::_decode("ids", search__ids_query(to_json($r)))->{value}
}

## Lucene query_string. %opts{default_field} or %opts{fields} optional.
fn Search::query_string ($query, %opts) {
    val $r = { query => $query, default_field => $opts{default_field}, fields => $opts{fields} }
    Search::_decode("query_string", search__query_string(to_json($r)))->{value}
}

## simple_query_string (lenient syntax). %opts{fields} optional (arrayref).
fn Search::simple_query_string ($query, %opts) {
    val $r = { query => $query, fields => $opts{fields} }
    Search::_decode("simple_query_string", search__simple_query_string(to_json($r)))->{value}
}

## geo_distance query — docs within $distance of ($lat, $lon) on $field.
fn Search::geo_distance ($field, $lat, $lon, $distance) {
    val $r = { field => $field, lat => $lat, lon => $lon, distance => $distance }
    Search::_decode("geo_distance", search__geo_distance_query(to_json($r)))->{value}
}

## nested query over $path with an inner $query clause.
fn Search::nested ($path, $query) {
    val $r = { path => $path, query => $query }
    Search::_decode("nested", search__nested_query(to_json($r)))->{value}
}

## constant_score wrapping a $filter clause. %opts{boost} optional.
fn Search::constant_score ($filter, %opts) {
    val $r = { filter => $filter, boost => $opts{boost} }
    Search::_decode("constant_score", search__constant_score(to_json($r)))->{value}
}

## dis_max over $queries (arrayref of clauses). %opts{tie_breaker} optional.
fn Search::dis_max ($queries, %opts) {
    val $list = ref($queries) eq "ARRAY" ? $queries : [$queries]
    val $r = { queries => $list, tie_breaker => $opts{tie_breaker} }
    Search::_decode("dis_max", search__dis_max(to_json($r)))->{value}
}

# ── full-body composers + field helpers (no connection) ───────────────

## Compose a full search body. %parts: query, aggs, sort, size, from,
## _source, highlight, track_total_hits, search_after, collapse.
fn Search::query_body (%parts) {
    Search::_decode("query_body", search__query_body(to_json(\%parts)))->{value}
}

## Sort clause `[{ $field => { order } }]`. %opts{order} default "asc".
fn Search::sort ($field, %opts) {
    val $r = { field => $field, order => $opts{order} // "asc" }
    Search::_decode("sort", search__sort_clause(to_json($r)))->{value}
}

## Highlight clause for $fields (arrayref).
fn Search::highlight ($fields) {
    val $list = ref($fields) eq "ARRAY" ? $fields : [$fields]
    val $r = { fields => $list }
    Search::_decode("highlight", search__highlight_clause(to_json($r)))->{value}
}

