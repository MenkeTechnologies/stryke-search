    val $r = { field => $field, value => $value }
    Search::_decode("regexp", search__regexp_query(to_json($r)))->{value}
}

## Fuzzy term query on $field. %opts{fuzziness} optional (e.g. "AUTO", 2).
fn Search::fuzzy ($field, $value, %opts) {
