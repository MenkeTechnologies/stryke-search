# ── aggregations runner ───────────────────────────────────────────────

## Run an aggregations search: `{ size:0, aggs:$aggs, query?:... }`. The
## `aggregations` block is on the response under `->{aggregations}`.
## %opts{query} scopes the aggs; %opts{size} returns hits too.
fn Search::search_aggs ($index, $aggs, %opts) {
    val $r = Search::_req(
        { index => $index, aggs => $aggs, query => $opts{query}, size => $opts{size} },
        \%opts
    )
    Search::_decode("search_aggs", search__search_aggs(to_json($r)))
}

# ── field caps + term vectors ─────────────────────────────────────────

## field_caps for $fields (arrayref) across %opts{index} (default `_all`).
fn Search::field_caps ($fields, %opts) {
    val $list = ref($fields) eq "ARRAY" ? $fields : [$fields]
    val $r = Search::_req({ index => $opts{index}, fields => $list }, \%opts)
    Search::_decode("field_caps", search__field_caps(to_json($r)))
}

## Term vectors for a document. %opts{id} for an existing doc; %opts{body}
## for an artificial doc / options.
fn Search::termvectors ($index, %opts) {
    val $r = Search::_req({ index => $index, id => $opts{id}, body => $opts{body} }, \%opts)
    Search::_decode("termvectors", search__termvectors(to_json($r)))
}

## Multi term vectors. $body: docs/ids request (hashref or JSON).
fn Search::mtermvectors ($body, %opts) {
    val $r = Search::_req({ index => $opts{index}, body => $body }, \%opts)
    Search::_decode("mtermvectors", search__mtermvectors(to_json($r)))
}

