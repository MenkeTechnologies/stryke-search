# ── point in time ─────────────────────────────────────────────────────

## Open a point-in-time on $index. %opts{keep_alive} default "1m". Returns
## `{ id => ... }`; pass that id in a search body's `pit`.
fn Search::pit_open ($index, %opts) {
    val $r = Search::_req({ index => $index, keep_alive => $opts{keep_alive} }, \%opts)
    Search::_decode("pit_open", search__pit_open(to_json($r)))
}

## Close a point-in-time by $id.
fn Search::pit_close ($id, %opts) {
    val $r = Search::_req({ id => $id }, \%opts)
    Search::_decode("pit_close", search__pit_close(to_json($r)))
}

