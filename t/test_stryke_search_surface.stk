## t/test_stryke_search_surface.stk — wrapper-completeness + pure-builder pin.
##
## Asserts every public `fn Search::name` declared in lib/Search.stk is
## reachable via `use` at runtime (`exists &Search::name` probes the symbol
## table without invoking the sub), then exercises the connection-free
## query-DSL builders for correct shape.
##
## Permission-free — no cluster, no creds. These asserts run anywhere, so CI
## without an Elasticsearch/OpenSearch container still validates the surface
## and the builder logic. Private helpers (`_` prefix) are implementation
## detail and are NOT asserted.

use Search

# ── wrapper surface ────────────────────────────────────────
assert_ok exists &Search::version, "Search::version exists"
assert_ok exists &Search::ping, "Search::ping exists"
assert_ok exists &Search::info, "Search::info exists"
assert_ok exists &Search::health, "Search::health exists"
assert_ok exists &Search::index_create, "Search::index_create exists"
assert_ok exists &Search::index_delete, "Search::index_delete exists"
assert_ok exists &Search::index_exists, "Search::index_exists exists"
assert_ok exists &Search::index_list, "Search::index_list exists"
assert_ok exists &Search::index_refresh, "Search::index_refresh exists"
assert_ok exists &Search::index_open, "Search::index_open exists"
assert_ok exists &Search::index_close, "Search::index_close exists"
assert_ok exists &Search::index_stats, "Search::index_stats exists"
assert_ok exists &Search::settings_get, "Search::settings_get exists"
assert_ok exists &Search::settings_update, "Search::settings_update exists"
assert_ok exists &Search::mapping_get, "Search::mapping_get exists"
assert_ok exists &Search::mapping_put, "Search::mapping_put exists"
assert_ok exists &Search::alias_add, "Search::alias_add exists"
assert_ok exists &Search::alias_remove, "Search::alias_remove exists"
assert_ok exists &Search::alias_get, "Search::alias_get exists"
assert_ok exists &Search::doc_index, "Search::doc_index exists"
assert_ok exists &Search::doc_get, "Search::doc_get exists"
assert_ok exists &Search::doc_exists, "Search::doc_exists exists"
assert_ok exists &Search::doc_update, "Search::doc_update exists"
assert_ok exists &Search::doc_delete, "Search::doc_delete exists"
assert_ok exists &Search::mget, "Search::mget exists"
assert_ok exists &Search::bulk, "Search::bulk exists"
assert_ok exists &Search::search, "Search::search exists"
assert_ok exists &Search::count, "Search::count exists"
assert_ok exists &Search::msearch, "Search::msearch exists"
assert_ok exists &Search::scroll_start, "Search::scroll_start exists"
assert_ok exists &Search::scroll_next, "Search::scroll_next exists"
assert_ok exists &Search::scroll_clear, "Search::scroll_clear exists"
assert_ok exists &Search::delete_by_query, "Search::delete_by_query exists"
assert_ok exists &Search::update_by_query, "Search::update_by_query exists"
assert_ok exists &Search::reindex, "Search::reindex exists"
assert_ok exists &Search::analyze, "Search::analyze exists"
assert_ok exists &Search::explain, "Search::explain exists"
assert_ok exists &Search::cat, "Search::cat exists"
assert_ok exists &Search::raw, "Search::raw exists"
assert_ok exists &Search::match_all, "Search::match_all exists"
assert_ok exists &Search::match, "Search::match exists"
assert_ok exists &Search::term, "Search::term exists"
assert_ok exists &Search::terms, "Search::terms exists"
assert_ok exists &Search::range, "Search::range exists"
assert_ok exists &Search::multi_match, "Search::multi_match exists"
assert_ok exists &Search::bool, "Search::bool exists"
assert_ok exists &Search::bulk_ndjson, "Search::bulk_ndjson exists"
assert_ok exists &Search::escape, "Search::escape exists"
assert_ok exists &Search::build_url, "Search::build_url exists"
assert_ok exists &Search::parse_url, "Search::parse_url exists"
assert_ok exists &Search::redact_url, "Search::redact_url exists"
# expanded query builders
assert_ok exists &Search::match_phrase, "Search::match_phrase exists"
assert_ok exists &Search::match_phrase_prefix, "Search::match_phrase_prefix exists"
assert_ok exists &Search::prefix, "Search::prefix exists"
assert_ok exists &Search::wildcard, "Search::wildcard exists"
assert_ok exists &Search::regexp, "Search::regexp exists"
assert_ok exists &Search::fuzzy, "Search::fuzzy exists"
assert_ok exists &Search::exists, "Search::exists exists"
assert_ok exists &Search::ids, "Search::ids exists"
assert_ok exists &Search::query_string, "Search::query_string exists"
assert_ok exists &Search::simple_query_string, "Search::simple_query_string exists"
assert_ok exists &Search::geo_distance, "Search::geo_distance exists"
assert_ok exists &Search::nested, "Search::nested exists"
assert_ok exists &Search::constant_score, "Search::constant_score exists"
assert_ok exists &Search::dis_max, "Search::dis_max exists"
# body composer + field helpers
assert_ok exists &Search::query_body, "Search::query_body exists"
assert_ok exists &Search::sort, "Search::sort exists"
assert_ok exists &Search::highlight, "Search::highlight exists"
# aggregations
assert_ok exists &Search::agg, "Search::agg exists"
assert_ok exists &Search::agg_terms, "Search::agg_terms exists"
assert_ok exists &Search::agg_avg, "Search::agg_avg exists"
assert_ok exists &Search::agg_sum, "Search::agg_sum exists"
assert_ok exists &Search::agg_min, "Search::agg_min exists"
assert_ok exists &Search::agg_max, "Search::agg_max exists"
assert_ok exists &Search::agg_stats, "Search::agg_stats exists"
assert_ok exists &Search::agg_extended_stats, "Search::agg_extended_stats exists"
assert_ok exists &Search::agg_cardinality, "Search::agg_cardinality exists"
assert_ok exists &Search::agg_value_count, "Search::agg_value_count exists"
assert_ok exists &Search::agg_percentiles, "Search::agg_percentiles exists"
assert_ok exists &Search::agg_histogram, "Search::agg_histogram exists"
assert_ok exists &Search::agg_date_histogram, "Search::agg_date_histogram exists"
assert_ok exists &Search::agg_range, "Search::agg_range exists"
assert_ok exists &Search::agg_filter, "Search::agg_filter exists"
assert_ok exists &Search::agg_missing, "Search::agg_missing exists"
assert_ok exists &Search::agg_nested, "Search::agg_nested exists"
assert_ok exists &Search::search_aggs, "Search::search_aggs exists"
# field caps + term vectors
assert_ok exists &Search::field_caps, "Search::field_caps exists"
assert_ok exists &Search::termvectors, "Search::termvectors exists"
assert_ok exists &Search::mtermvectors, "Search::mtermvectors exists"
# templates
assert_ok exists &Search::index_template_put, "Search::index_template_put exists"
assert_ok exists &Search::index_template_get, "Search::index_template_get exists"
assert_ok exists &Search::index_template_delete, "Search::index_template_delete exists"
assert_ok exists &Search::index_template_exists, "Search::index_template_exists exists"
assert_ok exists &Search::component_template_put, "Search::component_template_put exists"
assert_ok exists &Search::component_template_get, "Search::component_template_get exists"
assert_ok exists &Search::component_template_delete, "Search::component_template_delete exists"
# ingest pipelines
assert_ok exists &Search::ingest_put, "Search::ingest_put exists"
assert_ok exists &Search::ingest_get, "Search::ingest_get exists"
assert_ok exists &Search::ingest_delete, "Search::ingest_delete exists"
assert_ok exists &Search::ingest_simulate, "Search::ingest_simulate exists"
# point in time
assert_ok exists &Search::pit_open, "Search::pit_open exists"
assert_ok exists &Search::pit_close, "Search::pit_close exists"
# snapshot + repo
assert_ok exists &Search::repo_create, "Search::repo_create exists"
assert_ok exists &Search::repo_get, "Search::repo_get exists"
assert_ok exists &Search::repo_delete, "Search::repo_delete exists"
assert_ok exists &Search::snapshot_create, "Search::snapshot_create exists"
assert_ok exists &Search::snapshot_get, "Search::snapshot_get exists"
assert_ok exists &Search::snapshot_delete, "Search::snapshot_delete exists"
assert_ok exists &Search::snapshot_restore, "Search::snapshot_restore exists"
# tasks
assert_ok exists &Search::tasks_list, "Search::tasks_list exists"
assert_ok exists &Search::tasks_get, "Search::tasks_get exists"
assert_ok exists &Search::tasks_cancel, "Search::tasks_cancel exists"
# cluster + nodes
assert_ok exists &Search::cluster_stats, "Search::cluster_stats exists"
assert_ok exists &Search::cluster_state, "Search::cluster_state exists"
assert_ok exists &Search::cluster_settings_get, "Search::cluster_settings_get exists"
assert_ok exists &Search::cluster_settings_put, "Search::cluster_settings_put exists"
assert_ok exists &Search::nodes_info, "Search::nodes_info exists"
assert_ok exists &Search::nodes_stats, "Search::nodes_stats exists"
assert_ok exists &Search::pending_tasks, "Search::pending_tasks exists"
assert_ok exists &Search::allocation_explain, "Search::allocation_explain exists"
# stored scripts + search templates
assert_ok exists &Search::script_put, "Search::script_put exists"
assert_ok exists &Search::script_get, "Search::script_get exists"
assert_ok exists &Search::script_delete, "Search::script_delete exists"
assert_ok exists &Search::search_template, "Search::search_template exists"
assert_ok exists &Search::render_template, "Search::render_template exists"

# ── version (cdylib loaded) ────────────────────────────────
assert_ok Search::version(), "Search::version returns truthy (cdylib loaded)"

# ── pure query-DSL builders (no cluster) ───────────────────
# Builders return BARE clauses (no {query:...} wrapper); search() auto-wraps.
val $m = Search::match("title", "rust")
assert_eq $m->{match}{title}, "rust", "match builds bare match clause"

val $t = Search::term("status", "active")
assert_eq $t->{term}{status}{value}, "active", "term builds bare term clause"

val $ma = Search::match_all()
assert_ok exists $ma->{match_all}, "match_all builds bare match_all clause"

val $rg = Search::range("age", gte => 18, lt => 65)
assert_eq $rg->{range}{age}{gte}, 18, "range gte bound"
assert_eq $rg->{range}{age}{lt}, 65, "range lt bound"

val $b = Search::bool(must => [Search::match("a", "x")], filter => [Search::term("b", "y")])
assert_ok exists $b->{bool}{must}, "bool has must clause"
assert_ok exists $b->{bool}{filter}, "bool has filter clause"

# new query builders
assert_eq Search::match_phrase("t", "x y")->{match_phrase}{t}, "x y", "match_phrase"
assert_eq Search::prefix("f", "ru")->{prefix}{f}{value}, "ru", "prefix"
assert_eq Search::wildcard("f", "ru*")->{wildcard}{f}{value}, "ru*", "wildcard"
assert_ok exists Search::exists("f")->{exists}, "exists query"
assert_eq Search::exists("f")->{exists}{field}, "f", "exists field"
val $ids = Search::ids(["1", "2"])
assert_eq scalar(@{ $ids->{ids}{values} }), 2, "ids query has 2 ids"
assert_eq Search::query_string("foo AND bar")->{query_string}{query}, "foo AND bar", "query_string"

# aggregation builders
assert_eq Search::agg_terms("category", size => 5)->{terms}{field}, "category", "agg_terms field"
assert_eq Search::agg_terms("category", size => 5)->{terms}{size}, 5, "agg_terms size"
assert_eq Search::agg_avg("price")->{avg}{field}, "price", "agg_avg field"
assert_eq Search::agg_max("price")->{max}{field}, "price", "agg_max field"
assert_eq Search::agg_date_histogram("ts", calendar_interval => "day")->{date_histogram}{calendar_interval}, "day", "agg_date_histogram"

# full-body composer auto-includes the parts it is given
val $body = Search::query_body(query => Search::match("t", "x"), size => 10, aggs => { by_cat => Search::agg_terms("cat") })
assert_ok exists $body->{query}{match}, "query_body keeps query clause"
assert_eq $body->{size}, 10, "query_body keeps size"
assert_ok exists $body->{aggs}{by_cat}{terms}, "query_body keeps aggs"

# sort / highlight helpers
assert_eq Search::sort("ts", order => "desc")->[0]{ts}{order}, "desc", "sort clause order"
assert_ok exists Search::highlight(["title", "body"])->{fields}{title}, "highlight fields"

# ── escape + url helpers ───────────────────────────────────
assert_eq Search::escape("a+b"), "a\\+b", "escape escapes +"
assert_eq Search::escape("plain"), "plain", "escape leaves plain text"
assert_eq Search::redact_url("https://u:p\@h:9200"), "https://***\@h:9200", "redact strips userinfo"
assert_eq Search::build_url(host => "h", port => 9200), "http://h:9200", "build_url from parts"

val $pu = Search::parse_url("https://es.example.com:9243/prefix")
assert_eq $pu->{host}, "es.example.com", "parse_url host"
assert_eq $pu->{port}, 9243, "parse_url port"
assert_eq $pu->{scheme}, "https", "parse_url scheme"

# ── bulk NDJSON serialization (no cluster) ─────────────────
val $nd = Search::bulk_ndjson([
    { action => "index", index => "books", id => "1", document => { title => "a" } },
    { action => "delete", index => "books", id => "2" },
])
assert_ok index($nd, "\"_index\":\"books\"") >= 0, "bulk_ndjson emits index meta"
assert_ok index($nd, "\"delete\"") >= 0, "bulk_ndjson emits delete action"

test_run
